# Base URL for agest.vn (override for staging/local)
BASE_URL=https://www.agest.vn

# Grafana Cloud - k6 Prometheus Remote Write (optional)
# Get from: Grafana Cloud → Stack → Prometheus → Remote Write
# K6_PROMETHEUS_RW_SERVER_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
# K6_PROMETHEUS_RW_USERNAME=123456
# K6_PROMETHEUS_RW_PASSWORD=glc_xxx
